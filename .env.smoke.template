# Secrets are loaded from Docker secrets, not this env file.
# Required secret files (auto-generated or auto-touched in secrets/smoke/):
#   - secret_key.txt
#   - postgres_password.txt
#   - redis_password.txt
#   - (and all API keys as empty .txt files)
#
# DO NOT manually create API key files. Instead, use the automated command:
#   make set-llm PROVIDER=gemini
#   make set-llm PROVIDER=mock
POSTGRES_USER=admin
POSTGRES_DB=postgres
POSTGRES_SERVER=postgres
REDIS_HOST=redis
REDIS_PORT=6379
# Select profiles from configs/llm/models.yaml. Model names, base URLs,
# embedding dimensions, and API key precedence live in that YAML file.
LLM_PROVIDER=mock
RAG_EMBED_PROVIDER=mock
RAG_EMBED_BATCH_SIZE=10
ENABLE_OTEL_METRICS=false
ENABLE_OTEL_TRACES=false
OTEL_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# Full Grafana observability profile:
#   docker compose --env-file .env.smoke --env-file deploy/monitoring/observability.env.template --profile observability -f docker-compose.db.yml up
# ENABLE_OTEL_METRICS=true
# OTEL_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# PROMETHEUS_OTLP_ENDPOINT=http://otel-collector:4318/v1/metrics
# Langfuse tracing:
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
