# Secrets are loaded from Docker secrets, not this env file.
# Required secret files (auto-generated or auto-touched in secrets/smoke/):
#   - secret_key.txt
#   - postgres_password.txt
#   - redis_password.txt
#   - (and all API keys as empty .txt files)
#
# DO NOT manually create API key files. Instead, use the automated command:
#   make set-llm PROVIDER=gemini
#   make set-llm PROVIDER=mock

# ════════════════════════════════════════════════════════════════
# Infrastructure
# ════════════════════════════════════════════════════════════════
POSTGRES_USER=admin
POSTGRES_DB=postgres
POSTGRES_SERVER=postgres
REDIS_HOST=redis
REDIS_PORT=6379
CURRENT_UID=1000
CURRENT_GID=1000

# ════════════════════════════════════════════════════════════════
# Feature Toggles
# ════════════════════════════════════════════════════════════════
# Select profiles from configs/llm/models.yaml. Model names, base URLs,
# embedding dimensions, and API key precedence live in that YAML file.
LLM_PROVIDER=bifrost
# Bifrost gateway (required when LLM_PROVIDER=bifrost):
# BIFROST_API_KEY=sk-bf-change-me
# BIFROST_ENCRYPTION_KEY=change-me-to-a-long-random-passphrase
RAG_EMBED_PROVIDER=bifrost_embedding
RAG_EMBED_BATCH_SIZE=10

# ── RAG Retrieval (uncomment to override base defaults) ────────
# RAG_TOP_K=4
# RAG_RERANK_ENABLED=true
# RAG_RERANK_PROVIDER=bifrost
# RAG_RERANK_MODEL=qwen3-rerank
# RAG_RERANK_TIMEOUT_SECONDS=15
# RAG_RERANK_CANDIDATE_COUNT=20
# RAG_RERANK_TOP_K=4
# RAG_PLANNER_ENABLED=false
# RAG_PLANNER_PROVIDER=gemini
# RAG_PLANNER_TIMEOUT_SECONDS=8
# RAG_REFUSAL_ENABLED=true
# RAG_MIN_HIT_COUNT=1
# RAG_MIN_RELEVANCE_SCORE=0.2
# RAG_MIN_RERANK_SCORE=4.0

# ── Knowledge ──────────────────────────────────────────────────
# KNOWLEDGE_CHUNK_SIZE=800
# KNOWLEDGE_CHUNK_OVERLAP=120
# KNOWLEDGE_MAX_UPLOAD_SIZE_MB=20

# ── Chat / Rate ────────────────────────────────────────────────
AUTH_REGISTER_RATE_LIMIT_TIMES=100
# AUTH_REGISTER_RATE_LIMIT_SECONDS=60
# AUTH_LOGIN_RATE_LIMIT_TIMES=20
# AUTH_LOGIN_RATE_LIMIT_SECONDS=60
# BUSINESS_RATE_LIMIT_TIMES=100
# BUSINESS_RATE_LIMIT_SECONDS=60
# CHAT_RATE_LIMIT_TIMES=10
# CHAT_RATE_LIMIT_SECONDS=60

# ── Observability ──────────────────────────────────────────────
ENABLE_OTEL_METRICS=false
ENABLE_OTEL_TRACES=false
OTEL_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
# Full Grafana observability profile:
#   docker compose --env-file .env.smoke --env-file deploy/monitoring/observability.env.template --profile observability -f docker-compose.db.yml up
# ENABLE_OTEL_METRICS=true
# PROMETHEUS_OTLP_ENDPOINT=http://otel-collector:4318/v1/metrics
# Langfuse tracing:
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
