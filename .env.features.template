# ════════════════════════════════════════════════════════════════
# Dewflow Feature Toggle Reference
# ════════════════════════════════════════════════════════════════
#
# This file documents ALL feature toggles available in the application.
# Default values come from configs/app/base.yaml and are shown below.
# To override a default, set the environment variable in:
#   - Docker Compose: service `environment:` block
#   - Shell: export before running locally
#
# This file is NOT auto-loaded. It is a reference template.
# Copy specific entries to your Compose environment or .env file as needed.
# ════════════════════════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────────────────────
# Selects the LLM backend. See configs/llm/models.yaml for profiles.
LLM_PROVIDER=mock
# LLM_BASE_URL=
# LLM_MAX_CONTEXT_TOKENS=4096
# LLM_MAX_HISTORY_ROUNDS=10
# LLM_RESERVED_RESPONSE_TOKENS=1024
# LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# LLM_CIRCUIT_BREAKER_COOLDOWN_SECONDS=30

# ── Chat Streaming Timeouts ────────────────────────────────────
# CHAT_STREAM_FIRST_MESSAGE_TIMEOUT_SECONDS=30
# CHAT_STREAM_MESSAGE_TIMEOUT_SECONDS=10

# ── Chat Memory ───────────────────────────────────────────────
# CHAT_MEMORY_RECENT_ROUNDS=6
# CHAT_MEMORY_SUMMARY_MAX_CHARS=1500
# CHAT_MEMORY_SNIPPET_CHARS=120
# CHAT_MEMORY_FETCH_LIMIT=2000

# ── HTTP Rate Limiting ────────────────────────────────────────
AUTH_REGISTER_RATE_LIMIT_TIMES=10
AUTH_REGISTER_RATE_LIMIT_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_TIMES=20
AUTH_LOGIN_RATE_LIMIT_SECONDS=60
BUSINESS_RATE_LIMIT_TIMES=100
BUSINESS_RATE_LIMIT_SECONDS=60
CHAT_RATE_LIMIT_TIMES=10
CHAT_RATE_LIMIT_SECONDS=60

# ── RAG Embedding ─────────────────────────────────────────────
# Selects the embedding backend. See configs/llm/models.yaml for profiles.
RAG_EMBED_PROVIDER=mock
# RAG_EMBED_DIM=768
RAG_EMBED_BATCH_SIZE=10

# ── RAG Retrieval ─────────────────────────────────────────────
RAG_TOP_K=4
RAG_RERANK_ENABLED=false
RAG_RERANK_PROVIDER=
RAG_RERANK_MODEL=cohere/rerank-v3.5
RAG_RERANK_TIMEOUT_SECONDS=15
RAG_RERANK_CANDIDATE_COUNT=20
RAG_RERANK_TOP_K=4
RAG_PLANNER_ENABLED=false
RAG_PLANNER_PROVIDER=gemini
RAG_PLANNER_TIMEOUT_SECONDS=8
RAG_REFUSAL_ENABLED=true
RAG_MIN_HIT_COUNT=1
RAG_MIN_RELEVANCE_SCORE=0.2
RAG_MIN_RERANK_SCORE=4.0
# RAG_REFUSAL_MESSAGE=知识库中没有找到足够相关的信息，暂时无法基于资料回答。

# ── Knowledge Chunking ────────────────────────────────────────
KNOWLEDGE_CHUNK_SIZE=800
KNOWLEDGE_CHUNK_OVERLAP=120
KNOWLEDGE_MAX_UPLOAD_SIZE_MB=20
# KNOWLEDGE_INGEST_STALE_TIMEOUT_SECONDS=1800

# ── Search Text ───────────────────────────────────────────────
# SEARCH_TEXT_DEFAULT_TOKEN_LIMIT=60
# SEARCH_TEXT_KEYWORD_TOKEN_LIMIT=30
# SEARCH_TEXT_KEYWORD_REPEAT=2

# ── Worker Concurrency ────────────────────────────────────────
# LLM_MAX_CONCURRENCY=5
# DB_MAX_CONCURRENCY=10

# ── Observability ─────────────────────────────────────────────
# ENABLE_OTEL_METRICS=false
# ENABLE_OTEL_TRACES=false
# OTEL_TRACES_ENDPOINT=http://jaeger:4318/v1/traces
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
