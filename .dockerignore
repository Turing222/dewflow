# Git 版本控制
.git
.gitignore

# Python 虚拟环境
.venv
.venv_test_313
venv

# IDE/编辑器配置
.vscode
.idea
.DS_Store
.ipynb_checkpoints/

# 编译缓存
__pycache__
*.pyc
*.pyo
*.pyd

# 测试与覆盖率
.pytest_cache
.coverage
test/
tests/
htmlcov/

# 数据、日志与临时文件 (防止镜像过大并确保安全)
logs/
postgres_logs/
postgres_data/
redis_data/
*.log
tmp/
temp/
data/

# 部署配置与环境变量 (防止敏感信息泄露)
deploy/
.env
.env.*
secrets/
Dockerfile
.dockerignore

# 前端相关 (后端镜像不需要前端源码)
frontend/*
!frontend/pnpm-lock.yaml
!frontend/pnpm-workspace.yaml
!frontend/apps/
frontend/apps/*
!frontend/apps/admin/
!frontend/apps/admin/**
frontend/apps/admin/node_modules/
frontend/apps/admin/dist/
frontend/apps/admin/test-results/
frontend/apps/admin/playwright-report/
node_modules/

# 其它系统冗余
.files
